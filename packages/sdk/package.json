{
  "name": "@fluxy-chat/sdk",
  "version": "0.2.0",
  "description": "Fluxychat JavaScript/TypeScript SDK — WebSocket rooms, REST messages, FluxyRealtimeProvider, useChat with loadMore",
  "license": "MIT",
  "author": "Fluxychat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlessandroFare/fluxychat.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/AlessandroFare/fluxychat/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/AlessandroFare/fluxychat/issues"
  },
  "keywords": [
    "chat",
    "websocket",
    "realtime",
    "cloudflare",
    "fluxychat"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/room-connection.js",
    "dist/room-connection.d.ts",
    "dist/errors.js",
    "dist/errors.d.ts",
    "dist/message-stream.js",
    "dist/message-stream.d.ts",
    "dist/message-history.js",
    "dist/message-history.d.ts",
    "dist/jwt-utils.js",
    "dist/jwt-utils.d.ts",
    "dist/realtime-provider.js",
    "dist/realtime-provider.d.ts",
    "dist/use-fluxy-chat.js",
    "dist/use-fluxy-chat.d.ts",
    "dist/use-chat.js",
    "dist/use-chat.d.ts",
    "dist/use-rooms.js",
    "dist/use-rooms.d.ts",
    "dist/room-rest.js",
    "dist/room-rest.d.ts",
    "dist/agent-outbound.js",
    "dist/agent-outbound.d.ts",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "pnpm exec vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vitest": "^4.1.5"
  }
}
