# Public site URL for canonical links and Open Graph (production: https://fluxychat.dev)
# NEXT_PUBLIC_SITE_URL=https://fluxychat.dev

# --- Hosted-first (Fluxychat Cloud) ---
# Production/staging API (dashboard + SDK default when set):
# NEXT_PUBLIC_FLUXYCHAT_CLOUD_URL=https://api.fluxychat.com
#
# Local dev: run `pnpm dev` in apps/worker, then use localhost below.
# If CLOUD_URL is set, it wins over WORKER_URL.

# Worker base URL (browser + server). Used when CLOUD_URL is unset.
NEXT_PUBLIC_FLUXYCHAT_WORKER_URL=http://127.0.0.1:8787

# Optional: require /enter acknowledgment before console routes (see lib/dashboard-access.ts)
# DASHBOARD_ACCESS_MODE=ack
# CONSOLE_GATE_SECRET=

# Optional: strict CSP + security headers on console routes (see middleware.ts)
# DASHBOARD_CSP_ENABLED=true

# --- Clerk (hosted console sign-in) ---
# Save .env.local as UTF-8 (not UTF-16). On Windows Notepad: Save as → UTF-8.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# Optional redirect URLs (also set in Clerk Dashboard → Paths):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Bootstrap project API key on the hosted Worker (creates per-user tenants via /admin/projects).
# Create one platform project on the Worker, paste its fc_... key here — never expose to the browser.
# FLUXY_CONSOLE_API_KEY=fc_...
# Optional: pin all console users to one existing project (dev only; prefer per-user provisioning)
# FLUXY_CONSOLE_PROJECT_ID=
# FLUXY_PLATFORM_PROJECT_ID=
# Mirror for console UI (platform-operator tools on Projects); same UUID as above:
# NEXT_PUBLIC_FLUXY_PLATFORM_PROJECT_ID=

# --- Playwright E2E (apps/dashboard) ---
# Smoke (CI): pnpm test:e2e:smoke — no worker; unset Clerk keys above.
# Integrated: E2E_ADMIN_JWT=<admin-jwt> pnpm test:e2e:integrated (starts worker + dashboard via playwright.integrated.config.ts)

# Clerk webhook (optional — eager tenant provision on sign-up)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# DASHBOARD_PUBLIC_URL=https://console.fluxychat.com
